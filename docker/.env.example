# === StockPulse Docker Environment ===

# App
APP_PORT=8080

# PostgreSQL
POSTGRES_DB=stockpulse
DB_USERNAME=stockpulse
DB_PASSWORD=stockpulse
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# JWT
JWT_SECRET=default-dev-secret-must-be-at-least-32-characters-long

# External APIs
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
YAHOO_BASE_URL=https://query1.finance.yahoo.com
